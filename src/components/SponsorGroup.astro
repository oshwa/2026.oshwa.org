---
interface Props {
    name: string;
    columns: 1 | 2 | 3 | 4;
}

const { name, columns } = Astro.props;
---

<h3 class="drop-highlight">{name}</h3>
<ul data-columns={columns}>
    <slot />
</ul>

<style>
    h3 {
        text-align: center;
        margin-block-start: 3rem;
        font-size: var(--bulma-size-4);
        font-family: var(--ohs-family-display);
        font-weight: bold;
        line-height: 1.75rem;
    }

    ul {
        display: grid;
        margin-block: 0;
        margin-inline: 0;
        padding-inline: 0;
        padding-block: 0;
        align-items: start;
        justify-content: center;
        gap: 4rem 5rem;
        list-style: none;
        margin-block-start: 2rem;
        grid-template-columns: 0.5fr;

        &[data-columns="2"] {
            grid-template-columns: repeat(4, 1fr);

            li {
                grid-column: span 2;
            }
            li:nth-last-child(1):nth-child(odd) {
                grid-column: 2 / span 2;
            }
        }

        &[data-columns="3"] {
            grid-template-columns: repeat(6, 1fr);

            li {
                grid-column: span 2;
            }
            li:last-child:nth-child(3n - 1) {
                grid-column-end: -2;
            }
            li:nth-last-child(2):nth-child(3n + 1) {
                grid-column-end: 4;
            }
            li:last-child:nth-child(3n - 2) {
                grid-column-end: 5;
            }
        }

        &[data-columns="4"] {
            grid-template-columns: 1fr 1fr 1fr 1fr;
            gap: 2.5rem;
        }
    }
</style>
